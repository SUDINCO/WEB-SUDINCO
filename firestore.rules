
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isSignedIn() && request.auth.token.email == 'master@sudinco.com';
    }

    function isMasterOrAdmin() {
      if (isMaster()) {
        return true;
      }
      if (!isSignedIn()) {
        return false;
      }
      // Workaround for potential auth UID mismatches for specific admin users.
      if (request.auth.token.email == 'jaespinoza@sudinco.com') {
        return true;
      }
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return false;
      }
      let userData = getUserData();
      return userData.rol == 'MASTER' || userData.rol == 'ADMINISTRADOR';
    }
    
    // --- Collection Rules ---

    // USERS: Users can update their own data. Admins/Masters can update any user.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId) || isMasterOrAdmin();
      allow create: if isMasterOrAdmin();
      allow delete: if isMaster();
    }
    
    // ROLES: Only Master can manage roles. All signed-in users can read them.
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isMaster(); 
    }

    // CONSULTANT GROUPS: Only Master or Admin can manage consultant groups.
    match /consultantGroups/{groupId} {
      allow read, write: if isMasterOrAdmin();
    }

    // PERFORMANCE EVALUATIONS: 
    match /performanceEvaluations/{evaluationId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isMasterOrAdmin() || (isSignedIn() && (
        request.auth.token.email == resource.data.observerEmail
        ||
        (request.auth.uid == resource.data.evaluatorId && 
         resource.data.observerStatus == 'review_requested')
      ));
      allow delete: if isMaster();
    }

    // MANAGER EVALUATIONS: Employees evaluate their managers.
    match /managerEvaluations/{evaluationId} {
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow read: if isMasterOrAdmin() || (isSignedIn() && (resource.data.managerId == request.auth.uid || resource.data.employeeId == request.auth.uid));
      allow update, delete: if isMaster();
    }

    // VACATION REQUESTS: Users manage their own requests.
    match /vacationRequests/{requestId} {
        allow create: if isMasterOrAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
        allow get: if isMasterOrAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow list: if isSignedIn();
        allow update: if isMasterOrAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending');
        allow delete: if isMasterOrAdmin() || isOwner(resource.data.userId);
    }

    // LEADER ASSIGNMENT RULES: Only Master/Admin can manage these rules.
    match /leaderAssignmentRules/{ruleId} {
        allow read, write: if isMasterOrAdmin();
    }
    
    // HOLIDAYS: Any signed-in user can read, but only Admins/Master can write.
    match /holidays/{holidayId} {
      allow read: if isSignedIn();
      allow write: if isMasterOrAdmin();
    }

    // GENERIC OPTION COLLECTIONS
    match /empresas/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /cargos/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /ubicaciones/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /areas/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /centrosCosto/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }

    // PUBLICATIONS: Permitir lectura a todos los usuarios autenticados
    match /publications/{publicationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isMasterOrAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }
    
    // SIMPLE EVENTS
    match /simpleEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
    }

    // ATTENDANCE RECORDS
    match /attendance/{recordId} {
      allow create: if isSignedIn() && request.resource.data.collaboratorId == request.auth.uid;
      allow read, update: if isMasterOrAdmin() || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
    }
    
    // WORK LOCATIONS
    match /workLocations/{locationId} {
        allow read: if isSignedIn();
        allow write: if isMasterOrAdmin();
    }
    
    // LOCATION REPORTS
    match /locationReports/{reportId} {
      allow read: if isMasterOrAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // MEMORANDUMS
    match /memorandums/{memoId} {
      allow read: if isSignedIn() && (resource.data.targetUserId == request.auth.uid || isMasterOrAdmin());
      allow create: if isMasterOrAdmin();
      allow update: if isSignedIn() && (isMasterOrAdmin() || resource.data.targetUserId == request.auth.uid);
      allow delete: if isMaster();
    }
  }
}
