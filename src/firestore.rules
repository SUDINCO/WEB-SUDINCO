
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda de Seguridad ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isSignedIn() && request.auth.token.email == 'master@sudinco.com';
    }

    function isMasterOrAdmin() {
      if (isMaster()) return true;
      if (!isSignedIn()) return false;
      
      // Validación especial para administrador principal
      if (request.auth.token.email == 'jaespinoza@sudinco.com') return true;
      
      // Verificación de rol en el documento del usuario
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) return false;
      let userData = getUserData();
      return userData.rol == 'MASTER' || userData.rol == 'ADMINISTRADOR';
    }
    
    // --- Reglas de Colecciones ---

    // USERS: Solo dueños pueden editar su perfil básico. Administradores gestionan nómina.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId) || isMasterOrAdmin();
      allow create: if isMasterOrAdmin();
      allow delete: if isMaster();
    }

    // PRIVACY CONSENTS: Estricto cumplimiento de privacidad. Solo el dueño accede a su consentimiento.
    match /privacyConsents/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // ROLES: Solo Master gestiona la matriz de permisos.
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isMaster(); 
    }

    // CONSULTANT GROUPS: Gestión restringida a administración.
    match /consultantGroups/{groupId} {
      allow read, write: if isMasterOrAdmin();
    }

    // PERFORMANCE EVALUATIONS: 
    match /performanceEvaluations/{evaluationId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isMasterOrAdmin() || (isSignedIn() && (
        request.auth.token.email == resource.data.observerEmail ||
        (request.auth.uid == resource.data.evaluatorId && resource.data.observerStatus == 'review_requested')
      ));
      allow delete: if isMaster();
    }

    // VACATION REQUESTS: Los usuarios gestionan sus propias solicitudes.
    match /vacationRequests/{requestId} {
        allow create: if isMasterOrAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
        allow get: if isMasterOrAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow list: if isSignedIn();
        allow update: if isMasterOrAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending');
        allow delete: if isMasterOrAdmin() || isOwner(resource.data.userId);
    }

    // MEMORANDUMS: Gestión documental con permisos jerárquicos.
    match /memorandums/{memoId} {
      allow read: if isSignedIn() && (resource.data.targetUserId == request.auth.uid || isMasterOrAdmin());
      allow create: if isMasterOrAdmin();
      allow update: if isSignedIn() && (
        (isMasterOrAdmin()) || 
        (resource.data.targetUserId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt', 'signedAt', 'signature', 'defense']))
      );
      allow delete: if isMaster();
    }

    match /memorandumCausals/{causalId} {
      allow read: if isSignedIn();
      allow write: if isMasterOrAdmin();
    }

    // OPCIONES GENÉRICAS (Empresas, Cargos, etc.): Solo lectura para usuarios, escritura para Admins.
    match /empresas/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /cargos/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /ubicaciones/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /areas/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }
    match /centrosCosto/{id} { allow read: if isSignedIn(); allow write: if isMasterOrAdmin(); }

    // ASISTENCIA Y DOTACIÓN
    match /attendance/{recordId} {
      allow read, update: if isMasterOrAdmin() || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.collaboratorId == request.auth.uid;
    }
    
    match /equipmentHandovers/{handoverId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.outgoingGuardId || 
        request.auth.uid == resource.data.incomingGuardId ||
        isMasterOrAdmin()
      );
    }

    // Bloqueo total para cualquier otra ruta no especificada
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
