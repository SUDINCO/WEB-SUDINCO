
{
  "entities": {
    "Memorandum": {
      "title": "Memorandum",
      "type": "object",
      "description": "Official company memorandum for employees.",
      "properties": {
        "code": { "type": "string", "description": "Unique code like MEM-2025-001" },
        "type": { "type": "string", "enum": ["Informativo", "Llamado de atención", "Amonestación escrita", "Sanción", "Inicio de proceso disciplinario", "Reconocimiento"] },
        "causalId": { "type": "string" },
        "causalTitle": { "type": "string" },
        "targetUserId": { "type": "string" },
        "targetUserName": { "type": "string" },
        "targetUserCargo": { "type": "string" },
        "issuerId": { "type": "string" },
        "issuerName": { "type": "string" },
        "issuerCargo": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "issued", "read", "signed", "rejected"] },
        "createdAt": { "type": "number" },
        "readAt": { "type": "number" },
        "signedAt": { "type": "number" },
        "signature": { "type": "string", "description": "Base64 signature of the employee" },
        "defense": { "type": "string", "description": "Employee's formal response/defense" }
      },
      "required": ["code", "type", "targetUserId", "issuerId", "content", "status", "createdAt"]
    },
    "MemorandumCausal": {
      "title": "Memorandum Causal",
      "type": "object",
      "description": "Predefined reasons for issuing a memorandum.",
      "properties": {
        "category": { "type": "string", "enum": ["Incumplimiento Laboral", "Conducta", "Operativa", "Administrativa", "Positiva"] },
        "title": { "type": "string" },
        "legalBasis": { "type": "string", "description": "Reference to Internal Regulation" },
        "severity": { "type": "string", "enum": ["N/A", "Leve", "Grave", "Muy Grave"] }
      },
      "required": ["category", "title", "severity"]
    },
    "PrivacyConsent": {
      "title": "Privacy Consent",
      "type": "object",
      "description": "User consent for personal data treatment according to LOPDP.",
      "properties": {
        "uid": { "type": "string" },
        "acceptedAt": { "type": "number" },
        "version": { "type": "string" },
        "accepted": { "type": "boolean" }
      },
      "required": ["uid", "acceptedAt", "version", "accepted"]
    },
    "EquipmentHandover": {
      "title": "Equipment Handover",
      "type": "object",
      "description": "Report of equipment status at shift changes for security guards.",
      "properties": {
        "location": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "outgoingGuardId": { "type": "string" },
        "outgoingGuardName": { "type": "string" },
        "incomingGuardId": { "type": "string" },
        "incomingGuardName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": { "type": "string", "enum": ["good", "issue"] },
              "notes": { "type": "string" }
            }
          }
        },
        "outgoingSignature": { "type": "string", "description": "Base64 data URI of the outgoing guard signature." },
        "timestamp": { "type": "number" },
        "attendanceRecordId": { "type": "string" }
      },
      "required": ["location", "date", "outgoingGuardId", "incomingGuardId", "items", "outgoingSignature", "timestamp"]
    },
    "Holiday": {
        "title": "Holiday",
        "type": "object",
        "description": "Represents a public holiday.",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the holiday."
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "The start date of the holiday."
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "The end date of the holiday."
          }
        },
        "required": ["name", "startDate", "endDate"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user in the system, who is also a worker in the company.",
      "properties": {
        "codigo": {
          "type": "string",
          "description": "The worker's code."
        },
        "cedula": {
          "type": "string",
          "description": "The worker's national ID."
        },
        "apellidos": {
          "type": "string",
          "description": "The worker's last names."
        },
        "nombres": {
          "type": "string",
          "description": "The worker's first names."
        },
        "fechaIngreso": {
          "type": "string",
          "format": "date",
          "description": "The worker's hiring date."
        },
        "fechaNacimiento": {
            "type": "string",
            "format": "date",
            "description": "The worker's date of birth."
        },
        "fechaEvaluacionAnual": {
            "type": "string",
            "format": "date",
            "description": "The custom annual evaluation date for this worker."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The worker's email address, used for login."
        },
        "empresa": {
          "type": "string",
          "description": "The company the worker belongs to."
        },
        "cargo": {
          "type": "string",
          "description": "The worker's job position."
        },
        "ubicacion": {
          "type": "string",
          "description": "The worker's location."
        },
        "departamento": {
          "type": "string",
          "description": "The department or area the worker belongs to."
        },
        "centroCosto": {
            "type": "string",
            "description": "The cost center associated with the worker."
        },
        "liderArea": {
          "type": "string",
          "description": "The area leader's email."
        },
        "consultor": {
          "type": "string",
          "description": "The consultant assigned."
        },
        "rol": {
          "type": "string",
          "description": "The user's role in the system, determines permissions."
        },
        "isLeader": {
            "type": "boolean",
            "description": "Indicates if the worker is an area leader."
        },
        "tipoContrato": {
          "type": "string",
          "enum": ["INDEFINIDO", "EMERGENTE"],
          "description": "The type of employment contract."
        },
        "Status": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ],
          "description": "The user's current status."
        },
        "requiresPasswordChange": {
            "type": "boolean",
            "description": "If true, the user must change their password on the next login."
        }
      },
      "required": [
        "codigo",
        "cedula",
        "apellidos",
        "nombres",
        "fechaIngreso",
        "fechaNacimiento",
        "email",
        "empresa",
        "cargo",
        "departamento",
        "Status",
        "rol",
        "tipoContrato"
      ]
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "Defines a user role and its associated permissions.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the role (e.g., 'Master', 'Supervisor')."
        },
        "permissions": {
          "type": "object",
          "description": "A map of module IDs to boolean flags indicating access.",
          "additionalProperties": {
            "type": "boolean"
          }
        }
      },
      "required": ["name", "permissions"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores information about company users/workers."
    },
    "/memorandums/{id}": {
      "schema": { "$ref": "#/entities/Memorandum" },
      "description": "Official company documents and disciplinary records."
    },
    "/memorandumCausals/{id}": {
      "schema": { "$ref": "#/entities/MemorandumCausal" },
      "description": "Predefined catalog of reasons for memorandums."
    }
  }
}
